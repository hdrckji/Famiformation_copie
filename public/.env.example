# ========================================
# FamiFormation - Configuration Environnement
# ========================================

# Base de données (IONOS)
DB_HOST=localhost
DB_NAME=nom_de_la_base
DB_USER=utilisateur_db
DB_PASSWORD=mot_de_passe_db

# Sécurité
SESSION_TIMEOUT=900
APP_DEBUG=false
APP_URL=https://famiformation.com/login.php
# Email
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=FamiFormation
MAIL_ADMIN=admin@example.com

# SMTP (utilisé si renseigné, sinon fallback à mail())
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=utilisateur_smtp
SMTP_PASS=mot_de_passe_smtp
SMTP_SECURE=tls

# Base de données planning (optionnel si distincte de la base principale)
PLANNING_DB_HOST=
PLANNING_DB_PORT=3306
PLANNING_DB_NAME=
PLANNING_DB_USER=
PLANNING_DB_PASSWORD=

# CRON (optionnel, pour sécuriser les appels via HTTP)
CRON_TOKEN=votre_token_secret_ici